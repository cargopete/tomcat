# TomCat configuration. Copy to .env and edit, then point the systemd unit at it
# (EnvironmentFile=/home/pi/tomcat/.env). Values shown are the code defaults
# (except TOMCAT_DUTY, noted below); uncomment and change only what you need.
# .env itself is gitignored.

# --- GPIO (BCM numbering) ---
#TOMCAT_PIR_GPIO=17
#TOMCAT_PWM_GPIO=18

# --- Ultrasonic drive ---
#TOMCAT_F_LOW_HZ=20000
#TOMCAT_F_HIGH_HZ=24000
#TOMCAT_SWEEP_STEP=250
#TOMCAT_SWEEP_TICK_S=0.020

# Duty cycle, range 0..1000000. 500000 = 50% (full). 250000 = 25% (~6 dB quieter,
# the recommended starting point for week one while you watch the dogs).
#TOMCAT_DUTY=250000

# --- Burst behaviour (seconds) ---
#TOMCAT_BURST_SECONDS=4.0
#TOMCAT_COOLDOWN_S=8.0

# --- Quiet hours (24h clock). Window wraps past midnight; start==end disables. ---
#TOMCAT_QUIET_START_H=22
#TOMCAT_QUIET_END_H=7

# --- Event log location ---
#TOMCAT_DB_PATH=/home/pi/catdeter.sqlite3
