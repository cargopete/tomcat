[Unit]
Description=TomCat dashboard (web view over the event log)
After=network.target

[Service]
Type=simple
User=pi
# Shares the same DB path config as the deterrent.
EnvironmentFile=-/home/pi/tomcat/.env
ExecStart=/usr/bin/python3 /home/pi/tomcat/dashboard/app.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
